architecture-beta
    group frontend(globe)[Frontend]
    group api(cloud)[Backend API]
    group data(database)[Data Layer]
    group external(globe)[External]

    service react(browser)[React SPA] in frontend
    service nginx(server)[Nginx Proxy] in api
    service ctrl(server)[Controllers] in api
    service svc(server)[Services] in api
    service repo(server)[Repositories] in api
    service pg(database)[PostgreSQL] in data
    service redis(database)[Redis Cache] in data
    service clerk(cloud)[Clerk Auth] in external
    service nvidia(cloud)[NVIDIA LLM] in external
    service jsearch(cloud)[JSearch API] in external
    service mailjet(cloud)[Mailjet SMTP] in external

    react{group}:R --> L:nginx{group}
    nginx:R --> L:ctrl
    ctrl:R --> L:svc
    svc:R --> L:repo
    repo:R --> L:pg{group}
    repo:T --> B:redis{group}
    ctrl{group}:T --> B:clerk{group}
    svc{group}:T --> B:nvidia{group}
    svc{group}:T --> B:jsearch{group}
    svc{group}:B --> T:mailjet{group}
